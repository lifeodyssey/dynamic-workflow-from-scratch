{
  "name": "dynamic-workflow-from-scratch",
  "version": "0.0.1",
  "description": "A from-scratch, runnable reimplementation of Claude Code dynamic workflows — sandboxed JS orchestration with prefix-chained journaled resume.",
  "type": "module",
  "license": "MIT",
  "engines": { "node": ">=20" },
  "bin": { "dwf": "bin/run.ts" },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo:mock": "tsx bin/run.ts examples/deep-research.workflow.js --mock",
    "demo": "tsx bin/run.ts examples/deep-research.workflow.js"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
